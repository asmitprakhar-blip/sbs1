		.yes-home-final-track.is-looping{
			animation:yesHomeFinalMarquee 40s linear infinite;
		}

		.yes-home-final-marquee:hover .yes-home-final-track{
			animation-play-state:paused;
		}

		.yes-home-final-scroll.is-dragging .yes-home-final-track{
			animation-play-state:paused;
		}

		@keyframes yesHomeFinalMarquee{
			0%{ transform:translateX(0); }
			100%{ transform:translateX(-50%); }
		}

		.yes-home-final-card{
