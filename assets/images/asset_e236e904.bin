<div class="yes-print-media-modal" id="yesPrintMediaModal">
  <div class="yes-print-media-modal-content">
    <button class="yes-print-media-close" id="yesPrintMediaClose" aria-label="Close">&times;</button>
    <img loading="lazy" decoding="async" decoding="async" id="yesPrintMediaLargeImage" class="yes-print-media-large" src="" alt="Expanded newspaper coverage">
    <div id="yesPrintMediaCaption" class="yes-print-media-large-caption"></div>
  </div>
</div>

<script>
  (function(){
    const cards = document.querySelectorAll('.yes-print-media-card');
    const modal = document.getElementById('yesPrintMediaModal');
    const modalImg = document.getElementById('yesPrintMediaLargeImage');
    const modalCaption = document.getElementById('yesPrintMediaCaption');
    const closeBtn = document.getElementById('yesPrintMediaClose');

    cards.forEach(card => {
      card.addEventListener('click', function(){
        const image = this.getAttribute('data-image');
        const caption = this.getAttribute('data-caption') || '';
        modalImg.src = image;
        modalCaption.textContent = caption;
        modal.classList.add('active');
        document.body.style.overflow = 'hidden';
      });
    });

    function closeModal(){
      modal.classList.remove('active');
      modalImg.src = '';
      document.body.style.overflow = '';
    }

    closeBtn.addEventListener('click', closeModal);

    modal.addEventListener('click', function(e){
      if(e.target === modal){
        closeModal();
      }
    });

    document.addEventListener('keydown', function(e){
      if(e.key === 'Escape' && modal.classList.contains('active')){
        closeModal();
      }
    });
  })();
</script>				</div>
					</div>
				</div>
				</div>
		
		
			</div>

	
</main>

