					<style>
  .yes-print-media-wrap{
    position: relative;
    padding: 18px 0 10px;
    background: linear-gradient(180deg, #f7fbff 0%, #eef5fb 100%);
    border-top: 1px solid rgba(13, 71, 161, 0.08);
    border-bottom: 1px solid rgba(13, 71, 161, 0.08);
    overflow: hidden;
  }

  .yes-print-media-header{
    width: min(1200px, 92%);
    margin: 0 auto 14px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .yes-print-media-title{
    margin: 0;
    font-size: 22px;
    font-weight: 700;
    color: #0b3d91;
    letter-spacing: 0.2px;
  }

  .yes-print-media-subtitle{
    margin: 0;
    font-size: 13px;
    color: #5f6f85;
  }

  .yes-print-media-track-outer{
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .yes-print-media-track{
    display: flex;
    width: max-content;
    gap: 18px;
    animation: yesPrintScroll 36s linear infinite;
    will-change: transform;
    padding: 8px 0 18px;
  }

  .yes-print-media-wrap:hover .yes-print-media-track{
    animation-play-state: paused;
  }

  @keyframes yesPrintScroll{
    0%{
      transform: translateX(0);
    }
    100%{
      transform: translateX(-50%);
    }
  }

  .yes-print-media-card{
    flex: 0 0 auto;
    width: 240px;
    height: 230px;
    background: #ffffff;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 8px 24px rgba(8, 40, 90, 0.10);
    border: 1px solid rgba(11, 61, 145, 0.08);
    cursor: pointer;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    display: flex;
    flex-direction: column;
  }

  .yes-print-media-card:hover{
    transform: translateY(-5px);
    box-shadow: 0 14px 30px rgba(8, 40, 90, 0.16);
  }

  .yes-print-media-thumb-wrap{
    width: 100%;
    height: 160px;
    overflow: hidden;
    background: #dfeaf8;
  }

  .yes-print-media-thumb{
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .yes-print-media-card-body{
    padding: 10px 12px 12px;
    text-align: left;
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .yes-print-media-label{
    font-size: 13px;
    font-weight: 600;
    color: #173b74;
    line-height: 1.4;
    margin: 0 0 4px;
  }

  .yes-print-media-note{
    font-size: 12px;
    color: #6c7a8f;
    margin: 0;
  }

  .yes-print-media-fade-left,
  .yes-print-media-fade-right{
    position: absolute;
    top: 0;
    width: 90px;
    height: 100%;
    z-index: 2;
    pointer-events: none;
  }

  .yes-print-media-fade-left{
    left: 0;
    background: linear-gradient(to right, #eef5fb 15%, rgba(238,245,251,0));
  }

  .yes-print-media-fade-right{
    right: 0;
    background: linear-gradient(to left, #eef5fb 15%, rgba(238,245,251,0));
  }

  .yes-print-media-modal{
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(6, 20, 43, 0.78);
    z-index: 99999;
    padding: 30px 16px;
    align-items: center;
    justify-content: center;
  }

  .yes-print-media-modal.active{
    display: flex;
  }

  .yes-print-media-modal-content{
    position: relative;
    width: min(900px, 96vw);
    max-height: 92vh;
    background: #ffffff;
    border-radius: 18px;
    padding: 16px;
    box-shadow: 0 24px 60px rgba(0,0,0,0.28);
    animation: yesMediaPop 0.22s ease-out;
  }

  @keyframes yesMediaPop{
    from{
      opacity: 0;
      transform: scale(0.96);
    }
    to{
      opacity: 1;
      transform: scale(1);
    }
  }

  .yes-print-media-close{
    position: absolute;
    top: 10px;
    right: 12px;
    width: 38px;
    height: 38px;
    border: none;
    border-radius: 50%;
    background: #0b3d91;
    color: #fff;
    font-size: 22px;
    line-height: 1;
    cursor: pointer;
    box-shadow: 0 8px 18px rgba(11, 61, 145, 0.25);
  }

  .yes-print-media-large{
    width: 100%;
    max-height: 78vh;
    object-fit: contain;
    display: block;
    border-radius: 12px;
    background: #f4f8fd;
  }

  .yes-print-media-large-caption{
    margin: 12px 4px 2px;
    color: #173b74;
    font-size: 15px;
    font-weight: 600;
  }

  @media (max-width: 767px){
    .yes-print-media-title{
      font-size: 18px;
    }

    .yes-print-media-subtitle{
      font-size: 12px;
    }

    .yes-print-media-card{
      width: 190px;
      height: 200px;
    }

    .yes-print-media-thumb-wrap{
      height: 130px;
    }

    .yes-print-media-fade-left,
    .yes-print-media-fade-right{
      width: 40px;
    }
  }
</style>

<section class="yes-print-media-wrap">
  <div class="yes-print-media-header">
    <div>
      <h3 class="yes-print-media-title">Print Media Coverage</h3>
      <p class="yes-print-media-subtitle">Newspaper highlights featuring Young Entrepreneurs Summit 2026</p>
    </div>
  </div>

  <div class="yes-print-media-track-outer">
