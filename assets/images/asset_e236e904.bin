			box-shadow:0 14px 30px rgba(255,63,127,0.20);
			white-space:nowrap;
			transition:transform 0.2s ease, box-shadow 0.2s ease;
		}

		.yes-home-strategic-btn:hover{
			transform:translateY(-2px);
			box-shadow:0 18px 34px rgba(255,63,127,0.24);
			color:#fff;
		}

		.yes-home-strategic-scroll-wrap{
			position:relative;
			display:flex;
			align-items:center;
			gap:12px;
		}

		.yes-home-strategic-arrow{
			width:46px;
			height:46px;
			flex:0 0 46px;
			border:none;
			border-radius:999px;
			cursor:pointer;
			background:rgba(255,255,255,0.88);
			color:#0b1f4d;
			font-size:32px;
			line-height:1;
			display:flex;
			align-items:center;
			justify-content:center;
			box-shadow:0 10px 24px rgba(10,30,77,0.10);
			z-index:2;
			transition:all 0.2s ease;
		}

		.yes-home-strategic-arrow:hover{
			background:#ffffff;
			transform:translateY(-1px);
		}

		.yes-home-strategic-marquee{
			position:relative;
			flex:1 1 auto;
			overflow:hidden;
		}

		.yes-home-strategic-scroll{
			overflow-x:auto;
			overflow-y:hidden;
			scroll-behavior:smooth;
			-webkit-overflow-scrolling:touch;
			scrollbar-width:none;
			-ms-overflow-style:none;
		}

		.yes-home-strategic-scroll::-webkit-scrollbar{
			display:none;
		}

		.yes-home-strategic-track{
			display:flex;
			gap:22px;
			width:max-content;
			will-change:transform;
		}

		.yes-home-strategic-track.is-looping{
			animation:yesHomeStrategicMarquee 38s linear infinite;
		}

		.yes-home-strategic-marquee:hover .yes-home-strategic-track{
			animation-play-state:paused;
		}

		.yes-home-strategic-scroll.is-dragging .yes-home-strategic-track{
			animation-play-state:paused;
		}

		@keyframes yesHomeStrategicMarquee{
			0%{ transform:translateX(0); }
			100%{ transform:translateX(-50%); }
		}

		.yes-home-strategic-card{
			width:260px;
			min-width:260px;
			border-radius:24px;
			text-decoration:none;
			background:rgba(255,255,255,0.40);
			border:1px solid rgba(255,255,255,0.50);
			box-shadow:
				inset 0 1px 0 rgba(255,255,255,0.58),
				0 12px 30px rgba(10,30,77,0.08);
			backdrop-filter:blur(12px);
			padding:16px;
			transition:transform 0.2s ease, box-shadow 0.2s ease;
			overflow:hidden;
		}

		.yes-home-strategic-card:hover{
			transform:translateY(-4px);
			box-shadow:
				inset 0 1px 0 rgba(255,255,255,0.62),
				0 18px 38px rgba(10,30,77,0.12);
		}

		.yes-home-strategic-media{
			width:100%;
			height:138px;
			border-radius:18px;
			display:flex;
			align-items:center;
			justify-content:center;
			padding:10px;
			box-sizing:border-box;
			background:rgba(255,255,255,0.18);
			border:1px solid rgba(255,255,255,0.26);
			overflow:hidden;
		}

		.yes-home-strategic-media img{
			max-width:100%;
			max-height:100%;
			width:auto;
			height:auto;
			object-fit:contain;
			display:block;
		}

		.yes-home-strategic-fallback{
			width:58px;
			height:58px;
			border-radius:999px;
			background:linear-gradient(135deg,#1a2f7a 0%,#ff3f7f 100%);
			display:flex;
			align-items:center;
			justify-content:center;
			color:#fff;
			font-size:24px;
			font-weight:800;
		}

		.yes-home-strategic-meta{
			display:grid;
			gap:6px;
			text-align:center;
			margin-top:14px;
		}

		.yes-home-strategic-name{
			font-size:15px;
			line-height:1.5;
			font-weight:800;
			color:#0b1f4d;
			min-height:44px;
			display:flex;
			align-items:center;
			justify-content:center;
			text-align:center;
		}

		.yes-home-strategic-type{
			font-size:13px;
			line-height:1.65;
			font-weight:700;
			min-height:40px;
			display:flex;
			align-items:flex-start;
			justify-content:center;
			text-align:center;
			background:linear-gradient(135deg,#ff4b8b 0%,#d9236a 45%,#7d2cff 100%);
			-webkit-background-clip:text;
			background-clip:text;
			-webkit-text-fill-color:transparent;
		}

		@media (max-width:767px){
			.yes-home-strategic-wrap{
				padding:32px 0;
			}

			.yes-home-strategic-container{
				max-width:none;
			}

			.yes-home-strategic-section{
				padding:20px 8px 18px;
				border-radius:24px;
			}

			.yes-home-strategic-header{
				justify-content:center;
				text-align:center;
				padding:0 8px;
			}

			.yes-home-strategic-title{
				width:100%;
				text-align:center;
				font-size:24px;
			}

			.yes-home-strategic-btn{
				padding:12px 20px;
				font-size:13px;
			}

			.yes-home-strategic-scroll-wrap{
				gap:6px;
			}

			.yes-home-strategic-card{
				width:210px;
				min-width:210px;
			}

			.yes-home-strategic-media{
				height:118px;
			}

			.yes-home-strategic-arrow{
				width:38px;
				height:38px;
				flex:0 0 38px;
				font-size:26px;
			}

			.yes-home-strategic-track.is-looping{
				animation-duration:32s;
			}
		}
	</style>

	<script>
		document.addEventListener('DOMContentLoaded', function () {
			document.querySelectorAll('.yes-home-strategic-scroll-wrap').forEach(function(wrapper){
				const scrollBox = wrapper.querySelector('.yes-home-strategic-scroll');
				const track     = wrapper.querySelector('.yes-home-strategic-track');
				const prevBtn   = wrapper.querySelector('.yes-home-strategic-arrow.prev');
				const nextBtn   = wrapper.querySelector('.yes-home-strategic-arrow.next');

				if (!scrollBox || !track || !prevBtn || !nextBtn) return;

				const scrollAmount = 320;
				let isDown = false;
				let startX = 0;
				let scrollLeft = 0;

				prevBtn.addEventListener('click', function(){
					scrollBox.classList.add('is-dragging');
					scrollBox.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
					setTimeout(() => scrollBox.classList.remove('is-dragging'), 900);
				});

				nextBtn.addEventListener('click', function(){
					scrollBox.classList.add('is-dragging');
					scrollBox.scrollBy({ left: scrollAmount, behavior: 'smooth' });
					setTimeout(() => scrollBox.classList.remove('is-dragging'), 900);
				});

				scrollBox.addEventListener('mouseenter', function(){
					track.style.animationPlayState = 'paused';
				});

				scrollBox.addEventListener('mouseleave', function(){
					if (!scrollBox.classList.contains('is-dragging')) {
						track.style.animationPlayState = 'running';
					}
				});

				scrollBox.addEventListener('mousedown', function(e){
					isDown = true;
					scrollBox.classList.add('is-dragging');
					startX = e.pageX - scrollBox.offsetLeft;
					scrollLeft = scrollBox.scrollLeft;
					track.style.animationPlayState = 'paused';
				});

				scrollBox.addEventListener('mouseleave', function(){
					isDown = false;
					scrollBox.classList.remove('is-dragging');
					track.style.animationPlayState = 'running';
				});

				scrollBox.addEventListener('mouseup', function(){
					isDown = false;
					scrollBox.classList.remove('is-dragging');
					track.style.animationPlayState = 'running';
				});

				scrollBox.addEventListener('mousemove', function(e){
					if (!isDown) return;
					e.preventDefault();
					const x = e.pageX - scrollBox.offsetLeft;
					const walk = (x - startX) * 1.2;
					scrollBox.scrollLeft = scrollLeft - walk;
				});

				scrollBox.addEventListener('touchstart', function(){
					scrollBox.classList.add('is-dragging');
					track.style.animationPlayState = 'paused';
				}, { passive: true });

				scrollBox.addEventListener('touchend', function(){
					scrollBox.classList.remove('is-dragging');
					track.style.animationPlayState = 'running';
				}, { passive: true });
			});
		});
	</script>

