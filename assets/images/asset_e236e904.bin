<script>
  (function () {
    const eventDate = new Date("2026-06-26T09:30:00+05:30").getTime();

    function updateCountdown() {
      const now = new Date().getTime();
      const distance = eventDate - now;

      if (distance <= 0) {
        document.getElementById("yes-days").innerText = "00";
        document.getElementById("yes-hours").innerText = "00";
        document.getElementById("yes-minutes").innerText = "00";
        document.getElementById("yes-seconds").innerText = "00";
        return;
      }

      const days = Math.floor(distance / (1000 * 60 * 60 * 24));
      const hours = Math.floor((distance / (1000 * 60 * 60)) % 24);
      const minutes = Math.floor((distance / (1000 * 60)) % 60);
      const seconds = Math.floor((distance / 1000) % 60);

      document.getElementById("yes-days").innerText = String(days).padStart(2, "0");
      document.getElementById("yes-hours").innerText = String(hours).padStart(2, "0");
      document.getElementById("yes-minutes").innerText = String(minutes).padStart(2, "0");
      document.getElementById("yes-seconds").innerText = String(seconds).padStart(2, "0");
    }

    updateCountdown();
    setInterval(updateCountdown, 1000);
  })();
</script>				</div>
