<style id='y4g-events-header-buttons-inline-css' type='text/css'>

#top_login_button,
#top_sponsor_button {
	display:inline-flex !important;
	align-items:center;
	justify-content:center;
	white-space:nowrap;
	margin-right:6px;
	width:auto !important;
	max-width:none !important;
	flex:0 0 auto;
	padding:6px 16px !important;
	font-size:12px !important;
	line-height:1.1 !important;
	min-height:auto !important;
}

@media (max-width:1024px){
	#top_login_button,
	#top_sponsor_button {
		margin-right:6px;
		font-size:11px !important;
		padding:6px 12px !important;
	}
}

@media (min-width:1025px){
	#top_login_button,
	#top_sponsor_button {
		margin-right:8px;
		padding:6px 16px !important;
	}
}

/* Very small screens: compress buttons so both fit on one row. */
@media (max-width:600px){
	#top_login_button,
	#top_sponsor_button {
		font-size:11px;
		padding:5px 10px !important;
		margin-right:0 !important;
	}

	/* Hello Elementor dynamic header: enforce a 3-column header on mobile:
	   logo | login/sponsor buttons | hamburger menu */
	.site-header .header-inner{
		display:grid !important;
		grid-template-columns:auto 1fr auto !important;
		align-items:center;
		column-gap:12px;
	}
	/* If your theme/Elementor header builder wraps the header parts in
	   #top_navbar_box_custom, prefer that container for mobile layout. */
	#top_navbar_box_custom{
		display:grid !important;
		grid-template-columns:auto 1fr auto !important;
		align-items:center;
		column-gap:12px !important;
	}
	#top_navbar_box_custom .site-branding{
		grid-column:1 !important;
		justify-self:start !important;
	}
	#top_navbar_box_custom .site-navigation-toggle-holder{
		grid-column:3 !important;
		justify-self:end !important;
	}
	#top_navbar_box_custom .site-navigation{
		display:none !important;
	}
	#top_navbar_box_custom #y4g-header-buttons-box{
		grid-column:2 !important;
		display:flex !important;
		align-items:center !important;
		justify-content:center !important;
		gap:12px !important;
		min-width:0 !important;
	}
	.site-header .site-navigation{
		display:none !important;
	}
	.site-header .site-branding{
		grid-column:1 !important;
		justify-self:start;
	}
	#y4g-header-buttons-box{
		grid-column:2 !important;
		display:flex !important;
		align-items:center !important;
		justify-content:center !important;
		gap:12px !important;
		min-width:0 !important;
	}
	.site-header .site-navigation-toggle-holder{
		grid-column:3 !important;
		justify-self:end;
	}
}
		
/*# sourceURL=y4g-events-header-buttons-inline-css */
</style>
