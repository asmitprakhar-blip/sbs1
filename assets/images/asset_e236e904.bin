				background:rgba(255,255,255,0.90);
			}

			.yes-home-final-arrow.prev{
				left:6px;
			}

			.yes-home-final-arrow.next{
				right:6px;
			}

			.yes-home-final-arrow:hover{
				transform:translateY(-50%);
