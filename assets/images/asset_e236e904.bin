<style>
/* Ribbon Container */
.event-ribbon {
    width: 100%;
     color: #ffffff;
    overflow: hidden;
    position: relative;
    height: 44px;
    display: flex;
    align-items: center;
    font-family: Arial, Helvetica, sans-serif;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.5px;
    z-index: 9999;
}

/* Scrolling Track */
.event-ribbon-track {
    display: inline-block;
    white-space: nowrap;
    padding-left: 100%;
    animation: ribbon-scroll 20s linear infinite;
}

/* Text spacing */
.event-ribbon-track span {
    display: inline-block;
    padding-right: 80px;
}

/* Animation */
@keyframes ribbon-scroll {
    0% {
        transform: translateX(0);
    }
    100% {
        transform: translateX(-100%);
    }
}

/* Pause on hover */
.event-ribbon:hover .event-ribbon-track {
    animation-play-state: paused;
}

/* Mobile Responsive */
@media (max-width: 768px) {
    .event-ribbon {
        height: 36px;
        font-size: 12px;
    }
}
</style>

